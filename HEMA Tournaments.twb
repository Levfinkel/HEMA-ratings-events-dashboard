                </bin>
                <bin default-name='false' value='&quot;Sabre&quot;'>
                  <value>&quot;Mixed &amp; Men&apos;s Steel Sabre&quot;</value>
                  <value>&quot;Underrepresented Genders &amp; Women&apos;s Steel Sabre&quot;</value>
