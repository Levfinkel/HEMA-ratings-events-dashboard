      <aliases enabled='yes' />
      <column caption='Seasons' datatype='string' name='[Calculation_1115766847913717760]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE DATEPART(&apos;month&apos;, [EventDate])&#13;&#10;WHEN 12 THEN &quot;Winter&quot;&#13;&#10;WHEN  1 THEN &quot;Winter&quot;&#13;&#10;WHEN  2 THEN &quot;Winter&quot;&#13;&#10;WHEN  3 THEN &quot;Spring&quot;&#13;&#10;WHEN  4 THEN &quot;Spring&quot;&#13;&#10;WHEN  5 THEN &quot;Spring&quot;&#13;&#10;WHEN  6 THEN &quot;Summer&quot;&#13;&#10;WHEN  7 THEN &quot;Summer&quot;&#13;&#10;WHEN  8 THEN &quot;Summer&quot;&#13;&#10;WHEN  9 THEN &quot;Autumn&quot;&#13;&#10;WHEN 10 THEN &quot;Autumn&quot;&#13;&#10;WHEN 11 THEN &quot;Autumn&quot;&#13;&#10;END' />
      </column>
      <column caption='Fights per Event' datatype='integer' name='[Calculation_1115766847925972993]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// Fights per Event&#13;&#10;{ FIXED [EventID] : SUM([Fights]) }' />
      </column>
      <column caption='Number of fights per tournament' datatype='string' name='[Calculation_1115766848245719043]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='// Fight-count bucket (40-step, ending at 520)&#13;&#10;IF [Calculation_1115766847925972993] &lt;= 40 THEN &quot;0–40&quot;&#13;&#10;ELSEIF [Calculation_1115766847925972993] &lt;= 80 THEN &quot;41–80&quot;&#13;&#10;ELSEIF [Calculation_1115766847925972993] &lt;= 120 THEN &quot;81–120&quot;&#13;&#10;ELSEIF [Calculation_1115766847925972993] &lt;= 160 THEN &quot;121–160&quot;&#13;&#10;ELSEIF [Calculation_1115766847925972993] &lt;= 200 THEN &quot;161–200&quot;&#13;&#10;ELSEIF [Calculation_1115766847925972993] &lt;= 240 THEN &quot;201–240&quot;&#13;&#10;ELSEIF [Calculation_1115766847925972993] &lt;= 280 THEN &quot;241–280&quot;&#13;&#10;ELSEIF [Calculation_1115766847925972993] &lt;= 320 THEN &quot;281–320&quot;&#13;&#10;ELSEIF [Calculation_1115766847925972993] &lt;= 360 THEN &quot;321–360&quot;&#13;&#10;ELSEIF [Calculation_1115766847925972993] &lt;= 400 THEN &quot;361–400&quot;&#13;&#10;ELSEIF [Calculation_1115766847925972993] &lt;= 440 THEN &quot;401–440&quot;&#13;&#10;ELSEIF [Calculation_1115766847925972993] &lt;= 480 THEN &quot;441–480&quot;&#13;&#10;ELSEIF [Calculation_1115766847925972993] &lt;= 520 THEN &quot;481–520&quot;&#13;&#10;ELSE &quot;521+&quot;&#13;&#10;END' />
      </column>
      <column caption='Number of fighters (bucket)' datatype='string' name='[Calculation_1115766849993408516]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='// Fighters bucket (5-step, ending at 75)&#13;&#10;IF [Calculation_1533194241514016773] &lt;= 5 THEN &quot;0–5&quot;&#13;&#10;ELSEIF [Calculation_1533194241514016773] &lt;= 10 THEN &quot;6–10&quot;&#13;&#10;ELSEIF [Calculation_1533194241514016773] &lt;= 15 THEN &quot;11–15&quot;&#13;&#10;ELSEIF [Calculation_1533194241514016773] &lt;= 20 THEN &quot;16–20&quot;&#13;&#10;ELSEIF [Calculation_1533194241514016773] &lt;= 25 THEN &quot;21–25&quot;&#13;&#10;ELSEIF [Calculation_1533194241514016773] &lt;= 30 THEN &quot;26–30&quot;&#13;&#10;ELSEIF [Calculation_1533194241514016773] &lt;= 35 THEN &quot;31–35&quot;&#13;&#10;ELSEIF [Calculation_1533194241514016773] &lt;= 40 THEN &quot;36–40&quot;&#13;&#10;ELSEIF [Calculation_1533194241514016773] &lt;= 45 THEN &quot;41–45&quot;&#13;&#10;ELSEIF [Calculation_1533194241514016773] &lt;= 50 THEN &quot;46–50&quot;&#13;&#10;ELSEIF [Calculation_1533194241514016773] &lt;= 55 THEN &quot;51–55&quot;&#13;&#10;ELSEIF [Calculation_1533194241514016773] &lt;= 60 THEN &quot;56–60&quot;&#13;&#10;ELSEIF [Calculation_1533194241514016773] &lt;= 65 THEN &quot;61–65&quot;&#13;&#10;ELSEIF [Calculation_1533194241514016773] &lt;= 70 THEN &quot;66–70&quot;&#13;&#10;ELSEIF [Calculation_1533194241514016773] &lt;= 75 THEN &quot;71–75&quot;&#13;&#10;ELSE &quot;76+&quot;&#13;&#10;END' />
      </column>
      <column caption='Fights per Fighter' datatype='real' name='[Calculation_1115766850001915909]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// Fights per Fighter&#13;&#10;([Calculation_1115766847925972993] / [Calculation_1737826548927021056]) * 2' />
      </column>
      <column caption='Is selected event?' datatype='boolean' name='[Calculation_1533194241230270464]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='// Is selected event?&#13;&#10;[EventName] IN [Event Name Set]' />
      </column>
      <column caption='Selected bucket bar height' datatype='integer' name='[Calculation_1533194241230688257]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// Selected bucket bar height&#13;&#10;IF MIN(IIF([Calculation_1533194241502306306], 1, 0)) = 1 THEN&#13;&#10;    WINDOW_SUM(COUNTD([EventID]))&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Is in selected set' datatype='boolean' name='[Calculation_1533194241502306306]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='// Is in selected set (row-level)&#13;&#10;[EventName] IN [Event Name Set]' />
      </column>
      <column caption='Dot on top of selected bucket' datatype='integer' name='[Calculation_1533194241504325635]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// Dot on top of selected bucket&#13;&#10;IF { FIXED [EventID] :&#13;&#10;        MAX(INT(LOWER([EventName]) = LOWER([Parameters].[Parameter 1])))&#13;&#10;   } = 1&#13;&#10;THEN&#13;&#10;    { FIXED [Calculation_1533194241514876934] : COUNTD([EventID]) }&#13;&#10;END' />
      </column>
      <column caption='Is selected event (by parameter)' datatype='boolean' name='[Calculation_1533194241504407556]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='// Is selected event (by parameter)&#13;&#10;LOWER([EventName]) = LOWER([Parameters].[Parameter 1])' />
      </column>
      <column caption='Event entries (sum across divisions)' datatype='integer' name='[Calculation_1533194241514016773]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// Event entries (sum across divisions)&#13;&#10;{ FIXED [EventID] : SUM([Fighters]) }' />
      </column>
      <column caption='Fighters bucket (20-step)' datatype='string' name='[Calculation_1533194241514876934]' role='dimension' type='nominal'>
